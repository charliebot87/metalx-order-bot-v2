# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Database (leave empty for SQLite, set for PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Hyperion API endpoints (comma-separated, rotated on failure)
HYPERION_ENDPOINTS=https://proton.protonuk.io,https://proton-api.eosiomadrid.io,https://api-xprnetwork-main.saltant.io,https://xpr-mainnet-api.bloxprod.io,https://proton-hyperion.luminaryvisn.com,https://proton.eosusa.io

# RPC endpoints for on-chain table reads (comma-separated)
RPC_ENDPOINTS=https://api.protonnz.com,https://proton.greymass.com

# Poll interval in milliseconds (default: 3000)
POLL_INTERVAL=3000

# Max notifications per user per minute (default: 10)
RATE_LIMIT=10

# Max timestamp age on startup before resetting checkpoint to now (seconds, default: 300)
MAX_STALE_SECONDS=300

# Daily summary hour (0-23, in server's local timezone, default: 9)
DAILY_SUMMARY_HOUR=9

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
